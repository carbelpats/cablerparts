# =============================================================================
# Cabler Parts — environment variables (example)
#
# Copy this file to `.env` (or `.env.local`) and fill in real values, then
# configure the same vars in your host's dashboard (Vercel / Netlify).
#
# IMPORTANT: every VITE_* var is BUILD-TIME PUBLIC — Vite inlines it into the
# client bundle. Use ONLY publishable / anon keys here. Never put service-role
# keys or any server secret in a VITE_* var; those belong server-side.
#
# The app runs fully WITHOUT any of these set: each service falls back to a
# localStorage adapter, so previews and local dev work with no backend.
# =============================================================================

# --- Supabase (backend persistence) -----------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=
# Public anon key (Project Settings -> API -> anon/public). Safe to expose.
VITE_SUPABASE_ANON_KEY=

# --- Payments ----------------------------------------------------------------
# CLIENT/SERVER SPLIT (PCI): the keys below are PUBLISHABLE and belong on the
# client ONLY. The SECRET key, the actual charge/capture, refunds, and webhook
# verification MUST live server-side (a serverless function / your backend).
# Cards are tokenized by the provider's SDK and NEVER touch — or are stored on —
# our servers. The client gets a one-time token; the server performs the charge.
#
# Supported methods (surfaced in checkout): mada, Visa, Mastercard, Apple Pay,
# STC Pay, Cash on Delivery (COD), Tamara, Tabby. Which ones actually appear
# depends on the provider account + region you enable them in.
#
# Which payment processor to use: mock | moyasar | stripe | hyperpay | tap
# "mock" is the built-in test processor (no network, test cards only).
VITE_PAYMENT_PROVIDER=mock
# Moyasar PUBLISHABLE key, pk_... (only when VITE_PAYMENT_PROVIDER=moyasar).
VITE_MOYASAR_PUBLISHABLE_KEY=
# Moyasar SECRET key, sk_... — SERVER-SIDE ONLY. Set in Vercel (NOT a VITE_ var).
# Used by /api/payments/moyasar to verify charges. Never expose to the browser.
MOYASAR_SECRET_KEY=
# Stripe PUBLISHABLE key, pk_... (only when VITE_PAYMENT_PROVIDER=stripe).
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Shipping ----------------------------------------------------------------
# Which courier/fulfilment provider to use: mock | aramex | smsa | tryoto | imile
# "mock" is the built-in deterministic estimator (no network; generates a
# tracking number + ETA locally).
VITE_SHIPPING_PROVIDER=mock
# Shipping API key. NOTE on PCI-style separation of concerns:
#   - A *write* key (one that CREATES shipments / books pickups / buys labels)
#     must live SERVER-SIDE or behind a proxy — never in a VITE_* var.
#   - Only a *rate/read* key (quotes + tracking lookups) may sit client-side.
# Leave blank unless your provider issues a read-only rate key for the browser.
VITE_SHIPPING_API_KEY=
# SMSA API key — SERVER-SIDE ONLY. Set in Vercel (NOT a VITE_ var). Used by
# /api/shipping/smsa to fetch live rates / create shipments.
SMSA_API_KEY=

# --- Admin access ------------------------------------------------------------
# Comma-separated list of emails that get the "admin" role (storefront + the
# local auth adapter). Mirror these in Supabase by setting profiles.role='admin'.
VITE_ADMIN_EMAILS=admin@cablerparts.com
